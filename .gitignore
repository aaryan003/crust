# Database
*.db
*.sqlite
*.sqlite3
dump.sql

# Temporary
tmp/
temp/
*.tmp

# OS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Documentation
target/doc/
site/

# Test artifacts
test-repos/
test-*.crust/
