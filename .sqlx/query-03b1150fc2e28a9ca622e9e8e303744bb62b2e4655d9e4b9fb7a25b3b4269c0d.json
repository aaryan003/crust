  "query": "SELECT id, repo_id, number, title, description, author_id, state,\n                  head_ref, head_sha, base_ref, base_sha, created_at, updated_at\n           FROM pull_requests\n           WHERE repo_id = $1 AND state = $2\n           ORDER BY number DESC\n           LIMIT $3",
