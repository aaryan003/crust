{
  "db_name": "PostgreSQL",
  "query": "SELECT r.id, r.owner_id, r.name, r.display_name, r.description,\n                  r.is_public, r.default_branch, r.created_at, r.updated_at\n           FROM repositories r\n           JOIN users u ON r.owner_id = u.id\n           WHERE u.username = $1 AND r.name = $2",
