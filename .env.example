# Environment variables for CRUST deployment
# Copy this to .env and fill in values before running docker compose up

# PostgreSQL
DATABASE_URL=postgres://crust_user:crust_password@db:5432/crust
POSTGRES_USER=crust_user
POSTGRES_PASSWORD=crust_password
POSTGRES_DB=crust

# JWT Authentication (minimum 64 random characters)
JWT_SECRET=your-super-secret-jwt-key-here-minimum-64-characters-long

# Server Configuration
PORT=8080
LOG_LEVEL=info

# Repository Storage
REPO_BASE_PATH=/data/repos

# JWT Expiry
JWT_EXPIRY_SECONDS=86400

# Registration
ALLOW_REGISTRATION=true

# Optional: External Services
# GITHUB_WEBHOOK_SECRET=(for future webhook support)
# SLACK_WEBHOOK_URL=(for future notifications)
